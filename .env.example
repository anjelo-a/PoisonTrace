BASELINE_LOOKBACK_DAYS=90
SCAN_WINDOW_DAYS=7
LOOKALIKE_RECENCY_DAYS=30
LOOKALIKE_PREFIX_MIN=4
LOOKALIKE_SUFFIX_MIN=4
LOOKALIKE_SINGLE_SIDE_MIN=6
MIN_INJECTION_COUNT=2
