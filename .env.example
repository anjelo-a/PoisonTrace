DATABASE_URL=postgres://postgres:postgres@localhost:5432/chainguard?sslmode=disable
HELIUS_API_KEY=replace_me
HELIUS_BASE_URL=https://api.helius.xyz/v0
MAX_WALLETS_PER_RUN=25
MAX_TX_PAGES_PER_WALLET=20
